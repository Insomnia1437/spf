<Window x:Class="SPF.TunnelEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Configure Port Forwarding Tunnel"
        Height="660" Width="1000"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="spf_logo.png"
        Background="#F8FAFC"> <!-- Slate Light Page background -->

    <Window.Resources>
        <!-- Modern SaaS Form Styles -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="ui:ControlHelper.CornerRadius" Value="4"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#D8E2EF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
            <Setter Property="ui:ControlHelper.CornerRadius" Value="4"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#D8E2EF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="ui:ControlHelper.CornerRadius" Value="4"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderBrush" Value="#D8E2EF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ModernAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#4F46E5"/> <!-- Premium Indigo Accent -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ModernDefaultButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#D8E2EF"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top row: Type selection & Friendly Name -->
            <RowDefinition Height="*"/>    <!-- Main row: Dynamic Diagram Cards with inputs -->
            <RowDefinition Height="Auto"/> <!-- Bottom row: Buttons -->
        </Grid.RowDefinitions>

        <!-- 1. Top Settings Row -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Type Radio Buttons -->
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>    <!-- Name Input -->
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="Auto"/> <!-- Reconnect Checkbox -->
            </Grid.ColumnDefinitions>

            <!-- Segmented selector box -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Forwarding Type" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                <Border Background="#F1F5F9" CornerRadius="6" Padding="6" BorderBrush="#E2E8F0" BorderThickness="1">
                    <ui:SimpleStackPanel Orientation="Horizontal" Spacing="15">
                        <RadioButton x:Name="LocalRadio" Content="Local (-L)" IsChecked="True" Checked="TunnelType_Checked"
                                     Padding="4,0" FontSize="11" FontWeight="SemiBold"/>
                        <RadioButton x:Name="RemoteRadio" Content="Remote (-R)" Checked="TunnelType_Checked"
                                     Padding="4,0" FontSize="11" FontWeight="SemiBold"/>
                        <RadioButton x:Name="DynamicRadio" Content="Dynamic (-D)" Checked="TunnelType_Checked"
                                     Padding="4,0" FontSize="11" FontWeight="SemiBold"/>
                    </ui:SimpleStackPanel>
                </Border>
            </StackPanel>

            <!-- Friendly Name -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Tunnel Name" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox x:Name="NameInput" Style="{StaticResource ModernTextBoxStyle}" ui:ControlHelper.PlaceholderText="e.g. Workstation SSH Link"/>
            </StackPanel>

            <!-- Auto Reconnect -->
            <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,8">
                <CheckBox x:Name="AutoReconnectCheck" Content="Auto-reconnect" IsChecked="True"/>
            </StackPanel>
        </Grid>

        <!-- 2. Main Visual diagram cards containing the actual inputs -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/> <!-- Card 1: Local Node -->
                <ColumnDefinition Width="40"/> <!-- Arrow Spacer 1 -->
                <ColumnDefinition Width="1.2*"/> <!-- Card 2: SSH Server Node -->
                <ColumnDefinition Width="40"/> <!-- Arrow Spacer 2 -->
                <ColumnDefinition x:Name="RemoteCardColumn" Width="*"/> <!-- Card 3: Remote Destination Node -->
            </Grid.ColumnDefinitions>

            <!-- Card 1: Local PC -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#D8E2EF" Padding="18">
                <ui:SimpleStackPanel Spacing="15">
                    <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="💻" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LocalCardTitle" Text="Local PC" FontSize="13" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    </ui:SimpleStackPanel>

                    <Separator Background="#F1F5F9" Margin="0,0,0,5"/>

                    <ui:SimpleStackPanel Spacing="6">
                        <TextBlock Text="Local IP Bind Address:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                        <ComboBox x:Name="LocalIpCombo" Style="{StaticResource ModernComboBoxStyle}" IsEditable="True" Text="127.0.0.1"/>
                    </ui:SimpleStackPanel>

                    <ui:SimpleStackPanel Spacing="6">
                        <TextBlock Text="Local TCP Port:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                        <TextBox x:Name="LocalPortInput" Style="{StaticResource ModernTextBoxStyle}" ui:ControlHelper.PlaceholderText="e.g. 8080" PreviewTextInput="PortInput_PreviewTextInput"/>
                    </ui:SimpleStackPanel>
                </ui:SimpleStackPanel>
            </Border>

            <!-- Arrow 1: Local to SSH -->
            <Grid Grid.Column="1">
                <TextBlock x:Name="ArrowLocalToSsh" Text="➔" FontSize="24" FontWeight="Bold" Foreground="#4F46E5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Card 2: SSH Server (The Gateway) -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#D8E2EF" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ui:SimpleStackPanel Spacing="12">
                        <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🔒" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Text="SSH Gateway Server" FontSize="13" FontWeight="Bold" Foreground="#4F46E5" VerticalAlignment="Center"/>
                        </ui:SimpleStackPanel>

                        <Separator Background="#F1F5F9" Margin="0,0,0,5"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <ui:SimpleStackPanel Spacing="6">
                                <TextBlock Text="SSH Host:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                                <ComboBox x:Name="SshHostCombo" Style="{StaticResource ModernComboBoxStyle}" IsEditable="True" SelectionChanged="SshHostCombo_SelectionChanged" ui:ControlHelper.PlaceholderText="IP or alias"/>
                            </ui:SimpleStackPanel>
                            <ui:SimpleStackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Port:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                                <TextBox x:Name="SshPortInput" Style="{StaticResource ModernTextBoxStyle}" Text="22" PreviewTextInput="PortInput_PreviewTextInput"/>
                            </ui:SimpleStackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SimpleStackPanel Spacing="6">
                                <TextBlock Text="Username:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                                <TextBox x:Name="SshUserInput" Style="{StaticResource ModernTextBoxStyle}" ui:ControlHelper.PlaceholderText="e.g. root"/>
                            </ui:SimpleStackPanel>
                            <ui:SimpleStackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Authentication:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                                <ComboBox x:Name="AuthMethodCombo" Style="{StaticResource ModernComboBoxStyle}" SelectionChanged="AuthMethodCombo_SelectionChanged"/>
                            </ui:SimpleStackPanel>
                        </Grid>

                        <!-- Key Auth settings (Only shown when PrivateKey selected) -->
                        <ui:SimpleStackPanel x:Name="KeyAuthPanel" Spacing="10">
                            <ui:SimpleStackPanel Spacing="6">
                                <TextBlock Text="Private Key File:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SshKeyPathInput" Style="{StaticResource ModernTextBoxStyle}"/>
                                    <Button Grid.Column="1" Content="..." Margin="6,0,0,0" Click="BrowseKey_Click" Style="{StaticResource ModernDefaultButtonStyle}" Height="34" Padding="12,0"/>
                                </Grid>
                            </ui:SimpleStackPanel>

                            <ui:SimpleStackPanel Spacing="6">
                                <TextBlock Text="Key Passphrase (optional):" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                                <PasswordBox x:Name="KeyPassphraseInput" Style="{StaticResource ModernPasswordBoxStyle}"/>
                            </ui:SimpleStackPanel>
                        </ui:SimpleStackPanel>
                    </ui:SimpleStackPanel>
                </ScrollViewer>
            </Border>

            <!-- Arrow 2: SSH to Remote Destination -->
            <Grid Grid.Column="3" x:Name="ArrowSshToRemoteGrid">
                <TextBlock x:Name="ArrowSshToRemote" Text="➔" FontSize="24" FontWeight="Bold" Foreground="#4F46E5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Card 3: Remote Host -->
            <Border x:Name="RemoteCardBorder" Grid.Column="4" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#D8E2EF" Padding="18">
                <ui:SimpleStackPanel Spacing="15">
                    <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🌐" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RemoteCardTitle" Text="Remote Server" FontSize="13" FontWeight="Bold" Foreground="#047857" VerticalAlignment="Center"/>
                    </ui:SimpleStackPanel>

                    <Separator Background="#F1F5F9" Margin="0,0,0,5"/>

                    <ui:SimpleStackPanel Spacing="6">
                        <TextBlock Text="Destination Hostname/IP:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                        <TextBox x:Name="RemoteHostInput" Style="{StaticResource ModernTextBoxStyle}" ui:ControlHelper.PlaceholderText="e.g. 192.168.1.1"/>
                    </ui:SimpleStackPanel>

                    <ui:SimpleStackPanel Spacing="6">
                        <TextBlock Text="Destination Port:" FontSize="11" FontWeight="Bold" Foreground="#475569"/>
                        <TextBox x:Name="RemotePortInput" Style="{StaticResource ModernTextBoxStyle}" ui:ControlHelper.PlaceholderText="e.g. 80" PreviewTextInput="PortInput_PreviewTextInput"/>
                    </ui:SimpleStackPanel>
                </ui:SimpleStackPanel>
            </Border>
        </Grid>

        <!-- 3. Bottom Row: Save/Cancel buttons -->
        <ui:SimpleStackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Save Tunnel Config" Click="Save_Click" Style="{StaticResource ModernAccentButtonStyle}"/>
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource ModernDefaultButtonStyle}"/>
        </ui:SimpleStackPanel>
    </Grid>
</Window>
