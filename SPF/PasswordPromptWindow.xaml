<Window x:Class="SPF.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="SSH Password Authentication" 
        Height="245" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="spf_logo.png"
        Background="#F8FAFC">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Description -->
            <RowDefinition Height="*"/>    <!-- Input -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,15">
            <TextBlock Text="Password Authentication Required" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock x:Name="ServerDetailsLabel" Text="Connecting to user@host:port" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
        </StackPanel>

        <ui:SimpleStackPanel Grid.Row="1" Spacing="6" Margin="0,0,0,15">
            <TextBlock Text="Enter Password:" FontWeight="SemiBold" Foreground="#334155" FontSize="11"/>
            <PasswordBox x:Name="PasswordInput" ui:ControlHelper.CornerRadius="4" Height="34" Padding="10,6" BorderBrush="#E2E8F0" BorderThickness="1" Background="White"/>
        </ui:SimpleStackPanel>

        <ui:SimpleStackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <!-- Set IsDefault="True" to allow Enter key submission -->
            <Button Content="Connect" IsDefault="True" Click="Ok_Click" Style="{StaticResource AccentButtonStyle}" ui:ControlHelper.CornerRadius="4" Padding="18,6" FontWeight="SemiBold" Background="#4F46E5" Foreground="White" BorderThickness="0"/>
            <Button Content="Cancel" Click="Cancel_Click" ui:ControlHelper.CornerRadius="4" Padding="18,6" Background="White" BorderBrush="#E2E8F0"/>
        </ui:SimpleStackPanel>
    </Grid>
</Window>
