<Window x:Class="SPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="SimplePortForwarder (SPF)" 
        Height="780" Width="1140"
        WindowStartupLocation="CenterScreen"
        Icon="spf_logo.png"
        Background="#F8FAFC"> <!-- Modern slate light background -->
    
    <Window.Resources>
        <!-- Custom Modern Styles for a Premium SaaS Look -->
        
        <!-- Button Style Override -->
        <Style x:Key="ModernButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D8E2EF"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>

        <!-- Primary Accent Button Style -->
        <Style x:Key="ModernAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="ui:ControlHelper.CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#4F46E5"/> <!-- Premium Indigo Accent -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Column Header Style -->
        <Style x:Key="ModernColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>

        <!-- Cell Style to completely disable selection backgrounds and borders -->
        <Style x:Key="TransparentGridCellStyle" TargetType="DataGridCell">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row Style to completely disable selection highlights -->
        <Style x:Key="TransparentGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Menu Bar -->
            <RowDefinition Height="Auto"/> <!-- App Header -->
            <RowDefinition Height="Auto"/> <!-- Command bar / Toolbar -->
            <RowDefinition Height="*"/>    <!-- Main content (DataGrid) -->
            <RowDefinition Height="Auto"/> <!-- Splitter -->
            <RowDefinition Height="200" MinHeight="120"/> <!-- Log Console -->
        </Grid.RowDefinitions>

        <!-- 0. Menu Bar -->
        <Menu Grid.Row="0" Background="White" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="10,4">
            <MenuItem Header="File">
                <MenuItem Header="New Tunnel" Click="NewTunnel_Click" InputGestureText="Ctrl+N"/>
                <Separator/>
                <MenuItem Header="Import Config" Click="ImportConfig_Click"/>
                <MenuItem Header="Export Config" Click="ExportConfig_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Tunnels">
                <MenuItem Header="Start All" Click="StartAll_Click"/>
                <MenuItem Header="Stop All" Click="StopAll_Click"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About SPF" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- 1. App Title Header (Fluent style) -->
        <Border Grid.Row="1" Background="White" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" Background="#EEF2F6" CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Center">
                        <!-- Embed the compiled resource image -->
                        <Image Source="spf_logo.png" Margin="6"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Simple Port Forwarder" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Manage and monitor your SSH tunnels securely" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Right side: summary and open folder button -->
                <ui:SimpleStackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="15">
                    <TextBlock x:Name="TunnelsSummaryLabel" Text="Tunnels: 0 total | 0 active" FontSize="12" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                    <Separator Width="1" Height="20" Background="#CBD5E1"/>
                    <Button Content="📁 Open Config Folder" Click="OpenConfigFolder_Click" Style="{StaticResource ModernButtonStyle}" Padding="10,6" FontSize="11"/>
                </ui:SimpleStackPanel>
            </Grid>
        </Border>

        <!-- 2. Toolbar -->
        <Border Grid.Row="2" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Background="#F1F5F9" Padding="25,10">
            <Grid>
                <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="➕ New Tunnel" Click="NewTunnel_Click" Style="{StaticResource ModernAccentButtonStyle}"/>
                    <Separator Width="1" Margin="8,0" Background="#CBD5E1"/>
                    <Button Content="▶ Start All" Click="StartAll_Click" Style="{StaticResource ModernButtonStyle}"/>
                    <Button Content="⏹ Stop All" Click="StopAll_Click" Style="{StaticResource ModernButtonStyle}"/>
                    <Separator Width="1" Margin="8,0" Background="#CBD5E1"/>
                    <Button Content="📤 Export Config" Click="ExportConfig_Click" Style="{StaticResource ModernButtonStyle}"/>
                    <Button Content="📥 Import Config" Click="ImportConfig_Click" Style="{StaticResource ModernButtonStyle}"/>
                </ui:SimpleStackPanel>
            </Grid>
        </Border>

        <!-- 3. DataGrid of Tunnels -->
        <Border Grid.Row="3" Margin="25,20" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0">
            <DataGrid x:Name="TunnelsGrid" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      CanUserDeleteRows="False"
                      CanUserResizeColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                      CellStyle="{StaticResource TransparentGridCellStyle}"
                      RowStyle="{StaticResource TransparentGridRowStyle}"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="58"
                      Padding="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                
                <DataGrid.Resources>
                    <!-- Force ModernWpf theme keys to Transparent to kill highlight behaviors -->
                    <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="SystemControlHighlightListAccentMediumBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="SystemControlHighlightListAccentHighBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush" Color="Transparent"/>
                    <SolidColorBrush x:Key="SystemControlHighlightListHighBrush" Color="Transparent"/>
                    
                    <!-- Standard WPF selection overrides to Transparent -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#0F172A"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#0F172A"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Status Badge -->
                    <DataGridTemplateColumn Header="Status" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="6,3" Background="{Binding StatusBgBrush}" BorderBrush="{Binding StatusBrush}" BorderThickness="1" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="6" Height="6" Fill="{Binding StatusBrush}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding StatusDisplay}" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{Binding StatusTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Friendly Name -->
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Tunnel Type -->
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Local Binding IP:Port -->
                    <DataGridTextColumn Header="Local Bind" Binding="{Binding LocalDisplay}" Width="150" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- SSH credentials -->
                    <DataGridTextColumn Header="SSH Server" Binding="{Binding SshDisplay}" Width="220" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Destination host/port -->
                    <DataGridTextColumn Header="Destination" Binding="{Binding DestinationDisplay}" Width="150" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Action buttons (Start/Stop circle button, Edit, Copy, Delete horizontally) -->
                    <DataGridTemplateColumn Header="Actions" Width="235">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:SimpleStackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Circular Start/Stop button -->
                                    <Button Content="{Binding StartButtonSymbol}" Width="34" Height="34" Click="ToggleTunnel_Click" 
                                            Background="{Binding ActionButtonBg}" Foreground="White"
                                            ui:ControlHelper.CornerRadius="17" Padding="0" FontWeight="Bold" BorderThickness="0" FontSize="11"
                                            ToolTip="{Binding StartButtonText}"/>
                                    
                                    <!-- Edit button -->
                                    <Button Content="Edit" Width="55" Height="32" Click="EditTunnel_Click" IsEnabled="{Binding IsEditable}"
                                            ui:ControlHelper.CornerRadius="4" Padding="0" Background="White" BorderThickness="1" BorderBrush="#D8E2EF" FontSize="11" FontWeight="SemiBold"/>
                                    
                                    <!-- Copy button -->
                                    <Button Content="Copy" Width="55" Height="32" Click="CopyTunnel_Click" IsEnabled="{Binding IsEditable}"
                                            ui:ControlHelper.CornerRadius="4" Padding="0" Background="White" BorderThickness="1" BorderBrush="#D8E2EF" FontSize="11" FontWeight="SemiBold"/>
                                    
                                    <!-- Delete button -->
                                    <Button Content="Delete" Width="55" Height="32" Click="DeleteTunnel_Click" IsEnabled="{Binding IsEditable}" 
                                            ui:ControlHelper.CornerRadius="4" Padding="0" Background="White" BorderThickness="1" BorderBrush="#D8E2EF" FontSize="11" Foreground="#DC2626"/>
                                </ui:SimpleStackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 4. Splitter Grid -->
        <GridSplitter Grid.Row="4" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#CBD5E1" ResizeBehavior="PreviousAndNext"/>

        <!-- 5. Log Console Panel (Clean Light Theme styled) -->
        <Grid Grid.Row="5" Background="#F1F5F9">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border BorderThickness="0,0,0,1" BorderBrush="#D8E2EF" Padding="25,8" Background="White">
                <Grid>
                    <TextBlock Text="Log Console" FontWeight="Bold" Foreground="#475569" VerticalAlignment="Center" FontSize="12"/>
                    <Button Content="Clear Logs" HorizontalAlignment="Right" Click="ClearLogs_Click" 
                            Background="#EEF2F6" Foreground="#475569" ui:ControlHelper.CornerRadius="4" Padding="12,4" BorderBrush="#D8E2EF" BorderThickness="1" FontSize="11"/>
                </Grid>
            </Border>

            <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1" Background="White">
                <TextBox x:Name="LogTextBox" 
                         IsReadOnly="True" 
                         BorderThickness="0" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         FontFamily="Consolas" 
                         FontSize="12" 
                         Foreground="#334155"
                         Background="White"
                         Padding="20,15"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
